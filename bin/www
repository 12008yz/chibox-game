#!/usr/bin/env node
// ==== HTTP + SOCKET.IO СТАРТЕР (поддержка кластера: Redis сессии, rate-limit, Socket.IO adapter) ====

const fs = require('fs');
const http = require('http');
const path = require('path');
const socketIO = require('socket.io');
const jwt = require('jsonwebtoken');
const db = require('../models');
const authMiddleware = require('../middleware/auth');

function isRedisConnectionError(errLike) {
  const err = errLike && (errLike instanceof Error ? errLike : new Error(String(errLike)));
  const code = err?.code;
  const msg = err?.message || '';
  return code === 'ECONNRESET' ||
    code === 'ETIMEDOUT' ||
    code === 'ECONNREFUSED' ||
    code === 'ECONNABORTED' ||
    (typeof msg === 'string' && (msg.includes('ECONNRESET') || msg.includes('ECONNABORTED')));
}

// Защита процесса: не падаем при сетевых обрывах Redis.
process.on('unhandledRejection', (reason) => {
  if (isRedisConnectionError(reason)) {
    const msg = reason?.message || String(reason);
    console.warn('Redis: unhandledRejection (соединение), процесс не завершён:', msg);
    return;
  }
  console.error('Unhandled Rejection:', reason);
});

process.on('uncaughtException', (error) => {
  if (isRedisConnectionError(error)) {
    console.warn('Redis: uncaughtException (соединение), процесс не завершён:', error?.message || error);
    return;
  }
  console.error('Uncaught Exception:', error);
  process.exit(1);
});

function normalizePort(val) {
  const port = parseInt(val, 10);
  if (isNaN(port)) return val;
  if (port >= 0) return port;
  return false;
}

const port = normalizePort(process.env.PORT || '3000');

function getSSLOptions() {
  const certPath = process.env.SSL_CERT || path.join(__dirname, '../server.cert');
  const keyPath = process.env.SSL_KEY || path.join(__dirname, '../server.key');
  return {
    cert: fs.readFileSync(certPath),
    key: fs.readFileSync(keyPath),
  };
}

async function start() {
  const createApp = require('../app');
  const app = await createApp();
  app.set('port', port);

  const server = http.createServer(app);

  const MAX_CONNECTIONS = parseInt(process.env.MAX_HTTP_CONNECTIONS, 10) || 800;
  server.maxConnections = MAX_CONNECTIONS;
  server.timeout = 30000;
  server.keepAliveTimeout = 5000;
  server.headersTimeout = 10000;
  console.log('🛡️  Защита от DDoS:', `макс. соединений ${MAX_CONNECTIONS}`);

  const localSocketOrigins = ['http://localhost:5173', 'http://127.0.0.1:5173', 'http://localhost:3000'];
  const productionSocketOrigins = ['https://chibox-game.ru', 'https://www.chibox-game.ru', 'https://api.chibox-game.ru', 'https://streamer.chibox-game.ru'];
  const extraSocketOrigins = (process.env.SOCKET_CORS_ORIGINS || '')
    .split(',')
    .map((origin) => origin.trim())
    .filter(Boolean);
  const allowedSocketOrigins = Array.from(new Set([
    ...localSocketOrigins,
    ...(process.env.NODE_ENV === 'production' ? productionSocketOrigins : []),
    ...extraSocketOrigins
  ]));

  const io = socketIO(server, {
    cors: {
      origin: (origin, callback) => {
        if (!origin || allowedSocketOrigins.includes(origin)) {
          return callback(null, true);
        }
        return callback(new Error(`Socket CORS blocked origin: ${origin}`));
      },
      methods: ['GET', 'POST'],
      credentials: true
    },
    maxHttpBufferSize: 1e6,
    pingTimeout: 20000,
    pingInterval: 25000,
    connectTimeout: 10000
  });

  // Redis adapter для Socket.IO — при нескольких воркерах все инстансы видят одни и те же комнаты/события.
  // В development при USE_REDIS=false или SKIP_REDIS=true не подключаем Redis.
  const skipRedis = process.env.NODE_ENV === 'development' &&
    (process.env.USE_REDIS === 'false' || process.env.SKIP_REDIS === 'true');
  const redisSocketOptions = {
    connectTimeout: 10000,
    keepAlive: 10000,
    reconnectStrategy(retries) {
      if (retries > 50) return new Error('Redis max retries reached');
      return Math.min(retries * 100, 3000);
    },
  };
  const redisAdapterUrl = process.env.REDIS_MASTER_URL || process.env.REDIS_URL;
  if (redisAdapterUrl && !skipRedis) {
    try {
      const { createAdapter } = require('@socket.io/redis-adapter');
      const redis = require('redis');
      const pubClient = redis.createClient({
        url: redisAdapterUrl,
        socket: redisSocketOptions,
        pingInterval: 15000,
      });
      pubClient.on('error', (err) => {
        const code = err?.code || (err?.message && err.message.includes('ECONNRESET') ? 'ECONNRESET' : null);
        if (code === 'ECONNRESET' || code === 'ETIMEDOUT' || code === 'ECONNREFUSED') {
          console.warn('Redis PubClient: соединение потеряно, переподключение…', code);
        } else {
          console.error('Redis PubClient Error:', err.message);
        }
      });

      const subClient = pubClient.duplicate();
      subClient.on('error', (err) => {
        const code = err?.code || (err?.message && err.message.includes('ECONNRESET') ? 'ECONNRESET' : null);
        if (code === 'ECONNRESET' || code === 'ETIMEDOUT' || code === 'ECONNREFUSED') {
          console.warn('Redis SubClient: соединение потеряно, переподключение…', code);
        } else {
          console.error('Redis SubClient Error:', err.message);
        }
      });
      await Promise.all([pubClient.connect(), subClient.connect()]);
      io.adapter(createAdapter(pubClient, subClient));
      console.log('Socket.IO: Redis adapter включён (кластер)');
    } catch (err) {
      console.warn('Socket.IO: Redis adapter не подключён, работа в одном процессе:', err.message);
    }
  }

  const userSessions = new Map();
  const userConnections = new Map();
  const socketAuth = new Map(); // socketId -> { userIdKey, token }
  const ONLINE_BALANCE_TICK_MS = 1000;
  const ONLINE_BALANCE_INCREMENT = 3;
  let isBalanceTickRunning = false;

  const FAKE_ACTIVITY_ENABLED = process.env.FAKE_ACTIVITY_ENABLED === 'true' ||
    (process.env.NODE_ENV !== 'production' && process.env.FAKE_ACTIVITY_ENABLED !== 'false');
  const FAKE_ONLINE_MIN = Math.max(0, parseInt(process.env.FAKE_ONLINE_MIN, 10) || 15);
  const FAKE_ONLINE_MAX = Math.max(FAKE_ONLINE_MIN, parseInt(process.env.FAKE_ONLINE_MAX, 10) || 40);
  const FAKE_ONLINE_CACHE_MS = 60 * 1000; // новая цель раз в минуту
  const SMOOTH_STEP = 2; // макс. изменение за один вызов при движении к цели
  const IDLE_DRIFT = 2; // когда уже на цели — случайное ±1..2, чтобы не залипало на одном числе

  let displayOnlineCount = Math.floor((FAKE_ONLINE_MIN + FAKE_ONLINE_MAX) / 2);
  let fakeOnlineCached = { value: null, updatedAt: 0 };

  function getDisplayOnlineCount() {
    const realCount = userSessions.size;
    if (!FAKE_ACTIVITY_ENABLED) {
      displayOnlineCount = realCount;
      return realCount;
    }
    const now = Date.now();
    if (!fakeOnlineCached.value || now - fakeOnlineCached.updatedAt > FAKE_ONLINE_CACHE_MS) {
      fakeOnlineCached.value = FAKE_ONLINE_MIN + Math.floor(Math.random() * (FAKE_ONLINE_MAX - FAKE_ONLINE_MIN + 1));
      fakeOnlineCached.updatedAt = now;
    }
    const target = Math.max(realCount, fakeOnlineCached.value);
    let delta = Math.max(-SMOOTH_STEP, Math.min(SMOOTH_STEP, target - displayOnlineCount));
    if (delta === 0) {
      delta = Math.floor(Math.random() * (IDLE_DRIFT * 2 + 1)) - IDLE_DRIFT;
      delta = Math.max(-IDLE_DRIFT, Math.min(IDLE_DRIFT, delta));
    }
    displayOnlineCount = Math.max(realCount, Math.min(FAKE_ONLINE_MAX, Math.round(displayOnlineCount + delta)));
    return displayOnlineCount;
  }

  function broadcastOnlineUsers() {
    const count = getDisplayOnlineCount();
    io.emit('onlineUsersUpdate', { count });
    console.log(`Уникальных пользователей онлайн: ${count}${FAKE_ACTIVITY_ENABLED && count > userSessions.size ? ' (с учётом фейкового)' : ''}`);
  }

  function broadcastLiveDrop(dropData) {
    io.emit('liveDrop', dropData);
    console.log(`Live Drop отправлен: ${dropData.user.username} получил ${dropData.item.name}`);
  }

  function sendNotificationToUser(userId, notification) {
    const userIdKey = `user_${userId}`;
    const connections = userConnections.get(userIdKey);
    if (connections && connections.size > 0) {
      connections.forEach(socketId => {
        const socket = io.sockets.sockets.get(socketId);
        if (socket) {
          socket.emit('notification', notification);
          console.log(`Уведомление отправлено пользователю ${userId} (socket ${socketId}): ${notification.title}`);
        }
      });
    } else {
      console.log(`Пользователь ${userId} не онлайн, уведомление будет доставлено при следующем входе`);
    }
  }

  async function awardOnlineUsersBalance() {
    if (isBalanceTickRunning) return;
    const revokedTokens = authMiddleware.revokedTokens;
    const validUserKeys = new Set();

    for (const [socketId, auth] of socketAuth.entries()) {
      if (!auth?.userIdKey || !auth?.token) continue;
      if (revokedTokens?.has(auth.token)) continue;
      try {
        jwt.verify(auth.token, process.env.JWT_SECRET);
        validUserKeys.add(auth.userIdKey);
      } catch {
        // Токен просрочен/невалиден — больше не считаем этот сокет авторизованным
        socketAuth.delete(socketId);
      }
    }

    const onlineAuthUsers = Array.from(validUserKeys)
      .map((key) => key.slice(5));

    if (onlineAuthUsers.length === 0) return;

    isBalanceTickRunning = true;
    try {
      await db.User.increment(
        { balance: ONLINE_BALANCE_INCREMENT },
        { where: { id: onlineAuthUsers } }
      );

      const users = await db.User.findAll({
        where: { id: onlineAuthUsers },
        attributes: ['id', 'balance'],
        raw: true
      });

      users.forEach((user) => {
        const userIdKey = `user_${user.id}`;
        const sockets = userConnections.get(userIdKey);
        if (!sockets || sockets.size === 0) return;

        const nextBalance = Number(user.balance) || 0;
        sockets.forEach((socketId) => {
          const socket = io.sockets.sockets.get(socketId);
          if (socket) {
            socket.emit('balanceUpdate', {
              balance: nextBalance,
              delta: ONLINE_BALANCE_INCREMENT
            });
          }
        });
      });
    } catch (error) {
      console.error('Ошибка начисления онлайн-баланса:', error?.message || error);
    } finally {
      isBalanceTickRunning = false;
    }
  }

  function getSocketAuth(socket) {
    const session = socket.request.session;
    if (session && session.user && session.user.id) {
      return { userIdKey: `user_${session.user.id}`, token: null };
    }

    // Основной путь авторизации: JWT в httpOnly cookie accessToken
    const rawCookieHeader = socket.handshake?.headers?.cookie || '';
    if (rawCookieHeader && process.env.JWT_SECRET) {
      const cookieMap = rawCookieHeader.split(';').reduce((acc, part) => {
        const [key, ...rest] = part.trim().split('=');
        if (!key) return acc;
        acc[key] = decodeURIComponent(rest.join('=') || '');
        return acc;
      }, {});

      const accessToken = cookieMap.accessToken;
      if (accessToken) {
        try {
          const decoded = jwt.verify(accessToken, process.env.JWT_SECRET);
          if (decoded?.id) {
            return { userIdKey: `user_${decoded.id}`, token: accessToken };
          }
        } catch {
          // невалидный/просроченный токен — ниже будет guest fallback
        }
      }
    }

    const ip = socket.handshake.address;
    const userAgent = socket.handshake.headers['user-agent'] || 'unknown';
    const fingerprint = require('crypto').createHash('md5').update(ip + userAgent).digest('hex');
    return { userIdKey: `guest_${fingerprint}`, token: null };
  }

  io.on('connection', (socket) => {
    const auth = getSocketAuth(socket);
    const userId = auth.userIdKey;
    socketAuth.set(socket.id, auth);
    let isNewUser = false;
    if (!userSessions.has(userId)) {
      userSessions.set(userId, {
        id: userId,
        firstConnectedAt: new Date(),
        lastActivity: new Date()
      });
      isNewUser = true;
    } else {
      userSessions.get(userId).lastActivity = new Date();
    }
    if (!userConnections.has(userId)) {
      userConnections.set(userId, new Set());
    }
    userConnections.get(userId).add(socket.id);
    if (isNewUser) {
      console.log(`Socket.IO: Новый пользователь подключился (${userId}). Уникальных онлайн: ${userSessions.size}`);
    } else {
      console.log(`Socket.IO: Пользователь переподключился (${userId}). Соединений: ${userConnections.get(userId).size}`);
    }
    socket.emit('hello', { message: 'Привет через WebSocket!' });
    socket.emit('onlineUsersUpdate', { count: getDisplayOnlineCount() });
    broadcastOnlineUsers();
    socket.on('disconnect', (reason) => {
      socketAuth.delete(socket.id);
      const connections = userConnections.get(userId);
      if (connections) {
        connections.delete(socket.id);
        if (connections.size === 0) {
          userConnections.delete(userId);
          userSessions.delete(userId);
          console.log(`Socket.IO: Пользователь полностью отключился (${userId}, ${reason}). Уникальных онлайн: ${userSessions.size}`);
          broadcastOnlineUsers();
        } else {
          console.log(`Socket.IO: Одно из подключений пользователя закрыто (${userId}, ${reason}). Активных соединений: ${connections.size}`);
        }
      }
    });
    socket.on('error', (error) => {
      console.error('Socket.IO error:', error);
    });
  });

  setInterval(() => {
    const now = new Date();
    const fiveMinutesAgo = new Date(now.getTime() - 5 * 60 * 1000);
    let cleanedUsers = 0;
    for (const [userId, userData] of userSessions.entries()) {
      if (userData.lastActivity >= fiveMinutesAgo) continue;
      // Не снимать с учёта, пока есть живые сокеты: lastActivity обновляется только на
      // connection, а при долгом WebSocket без реконнекта иначе «выпадаем» из онлайна.
      const conns = userConnections.get(userId);
      if (conns && conns.size > 0) {
        userData.lastActivity = now;
        continue;
      }
      userSessions.delete(userId);
      userConnections.delete(userId);
      cleanedUsers++;
    }
    if (cleanedUsers > 0) {
      console.log(`Очищено неактивных пользователей: ${cleanedUsers}. Онлайн: ${userSessions.size}`);
      broadcastOnlineUsers();
    }
  }, 5 * 60 * 1000);

  const ONLINE_BROADCAST_INTERVAL_MS = 45 * 1000;
  setInterval(() => {
    broadcastOnlineUsers();
  }, ONLINE_BROADCAST_INTERVAL_MS);

  setInterval(() => {
    awardOnlineUsersBalance();
  }, ONLINE_BALANCE_TICK_MS);

  server.on('error', (error) => {
    if (error.syscall !== 'listen') throw error;
    const bind = typeof port === 'string' ? 'Pipe ' + port : 'Port ' + port;
    if (error.code === 'EACCES') {
      console.error(bind + ' требует повышенных привилегий');
      process.exit(1);
    } else if (error.code === 'EADDRINUSE') {
      console.error(bind + ' уже используется');
      process.exit(1);
    } else {
      throw error;
    }
  });

  server.on('listening', () => {
    const addr = server.address();
    const bind = typeof addr === 'string' ? 'pipe ' + addr : 'порт ' + addr.port;
    console.log('HTTP сервер запущен на ' + bind);
    console.log('Socket.IO готов.');
  });

  server.listen(port, '0.0.0.0');

  // Инициализируем LiveDrop сервис
  const { initLiveDropService } = require('../services/liveDropService');
  initLiveDropService(broadcastLiveDrop);

  if (FAKE_ACTIVITY_ENABLED) {
    const FAKE_DROP_MIN_SEC = 7;
    const FAKE_DROP_MAX_SEC = 15;
    let fakeDropBotIndex = 0;

    function scheduleNextFakeDrop() {
      const delayMs = parseInt(process.env.FAKE_DROP_INTERVAL_MS, 10) ||
        (FAKE_DROP_MIN_SEC + Math.random() * (FAKE_DROP_MAX_SEC - FAKE_DROP_MIN_SEC + 1)) * 1000;
      setTimeout(() => {
        const { getBots, runFakeCaseOpen } = require('../services/fakeActivityService');
        getBots()
          .then((bots) => {
            if (!bots.length) return;
            const bot = bots[fakeDropBotIndex % bots.length];
            fakeDropBotIndex += 1;
            return runFakeCaseOpen(bot.id);
          })
          .then(() => { scheduleNextFakeDrop(); })
          .catch((err) => {
            console.warn('[FakeActivity] Ошибка дропа, следующий по расписанию:', err?.message || err);
            scheduleNextFakeDrop();
          });
      }, delayMs);
    }

    scheduleNextFakeDrop();
    console.log(`[FakeActivity] Онлайн 15–40, дропы по одному каждые ${FAKE_DROP_MIN_SEC}–${FAKE_DROP_MAX_SEC} сек (очередь по боту).`);

    setInterval(() => {
      const { runBotSellOneItem } = require('../services/fakeActivityService');
      runBotSellOneItem();
    }, 6 * 60 * 60 * 1000);

    setInterval(() => {
      const { runBotClearInventoryBatch } = require('../services/fakeActivityService');
      runBotClearInventoryBatch();
    }, 2 * 60 * 60 * 1000);

    setInterval(() => {
      const { runBotDailyInventoryCleanup } = require('../services/fakeActivityService');
      runBotDailyInventoryCleanup();
    }, 24 * 60 * 60 * 1000);
    setImmediate(() => {
      const { runBotDailyInventoryCleanup } = require('../services/fakeActivityService');
      runBotDailyInventoryCleanup();
    });

    const upgradeIntervalMs = (20 + Math.floor(Math.random() * 21)) * 60 * 1000;
    setInterval(() => {
      const { runBotFakeUpgrade } = require('../services/fakeActivityService');
      runBotFakeUpgrade();
    }, upgradeIntervalMs);

    const gameIntervalMs = (10 + Math.floor(Math.random() * 16)) * 60 * 1000;
    setInterval(() => {
      const { runBotFakeGame } = require('../services/fakeActivityService');
      runBotFakeGame();
    }, gameIntervalMs);

    setImmediate(() => {
      const { getBots } = require('../services/fakeActivityService');
      getBots().then((bots) => {
        if (bots.length === 0) {
          console.log('[FakeActivity] В БД нет ботов — лента дропов будет пуста. Создайте ботов: node scripts/seed-fake-activity-bots.js 30');
        } else {
          console.log(`[FakeActivity] Ботов в БД: ${bots.length}, дропы по одному в ленту.`);
        }
      }).catch(() => {});
    });
  } else {
    console.log('[FakeActivity] Выключено. Чтобы включить ленту дропов и фейковый онлайн: FAKE_ACTIVITY_ENABLED=true в .env и перезапуск сервера.');
  }

  const { initNotificationSender } = require('../utils/notificationHelper');
  initNotificationSender(sendNotificationToUser);

  module.exports = { io, broadcastOnlineUsers, broadcastLiveDrop, sendNotificationToUser };
}

start().catch((err) => {
  console.error(err);
  process.exit(1);
});